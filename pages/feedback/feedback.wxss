/* pages/feedback/feedback.wxss */
.container { padding: 20rpx 30rpx; min-height: 100vh; background: #f5f6fa; box-sizing: border-box; }

.feedback-card { background: #fff; border-radius: 24rpx; padding: 36rpx; margin-bottom: 24rpx; }
.email-section { margin-bottom: 28rpx; }
.email-label { font-size: 26rpx; color: #999; margin-bottom: 16rpx; display: block; }
.email-row { display: flex; align-items: center; justify-content: space-between; background: #f5f7ff; border-radius: 16rpx; padding: 24rpx; }
.email-address { font-size: 28rpx; color: #667eea; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.copy-btn { padding: 10rpx 24rpx; background: #667eea; border-radius: 12rpx; flex-shrink: 0; margin-left: 16rpx; }
.copy-text { font-size: 24rpx; color: #fff; }

.action-btn { background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 16rpx; padding: 28rpx 0; text-align: center; }
.action-text { font-size: 30rpx; color: #fff; font-weight: 600; }

.tips-card { background: #fff; border-radius: 24rpx; padding: 36rpx; margin-bottom: 24rpx; }
.tips-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }
.tips-item { display: flex; align-items: flex-start; gap: 16rpx; margin-bottom: 24rpx; }
.tips-item:last-child { margin-bottom: 0; }
.tips-icon { font-size: 32rpx; flex-shrink: 0; margin-top: 2rpx; }
.tips-text { font-size: 26rpx; color: #666; line-height: 1.6; flex: 1; }

.footer { display: flex; justify-content: center; padding: 60rpx 0 40rpx; }
.footer-text { font-size: 24rpx; color: #ccc; }
