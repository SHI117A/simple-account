<view class="container">
  <view class="settings-card">
    <view class="card-title">数据管理</view>
    <view class="setting-item" bindtap="goImport">
      <view class="setting-left">
        <text class="setting-icon">📥</text>
        <view class="setting-info">
          <text class="setting-name">数据导入</text>
          <text class="setting-desc">从 CSV 或 Excel 文件导入记账数据</text>
        </view>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item" bindtap="exportData">
      <view class="setting-left">
        <text class="setting-icon">📤</text>
        <view class="setting-info">
          <text class="setting-name">导出数据</text>
          <text class="setting-desc">将记账数据复制为 CSV，可粘贴到 Excel</text>
        </view>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item danger" bindtap="clearData">
      <view class="setting-left">
        <text class="setting-icon">🗑️</text>
        <view class="setting-info">
          <text class="setting-name">清空所有数据</text>
          <text class="setting-desc">删除全部记账记录，此操作不可恢复</text>
        </view>
      </view>
      <text class="setting-arrow">›</text>
    </view>
  </view>

  <view class="settings-card">
    <view class="card-title">关于</view>
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">📱</text>
        <view class="setting-info">
          <text class="setting-name">简记账</text>
          <text class="setting-desc">一款极简的微信小程序记账工具</text>
        </view>
      </view>
    </view>
    <view class="setting-item" bindtap="goFeedback">
      <view class="setting-left">
        <text class="setting-icon">✉️</text>
        <view class="setting-info">
          <text class="setting-name">反馈与建议</text>
          <text class="setting-desc">联系作者，提交问题或建议</text>
        </view>
      </view>
      <text class="setting-arrow">›</text>
    </view>
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">💾</text>
        <view class="setting-info">
          <text class="setting-name">数据存储</text>
          <text class="setting-desc">数据保存在本地，无需登录注册</text>
        </view>
      </view>
    </view>
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-icon">📊</text>
        <view class="setting-info">
          <text class="setting-name">记录统计</text>
          <text class="setting-desc">共 {{totalCount}} 条记录</text>
        </view>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">简记账 v1.3.0</text>
    <text class="footer-text">支持 CSV / XLSX 导入 </text>
  </view>
</view>
