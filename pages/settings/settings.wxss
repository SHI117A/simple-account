.settings-card { background: #fff; border-radius: 24rpx; padding: 36rpx; margin-bottom: 24rpx; }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 24rpx; }
.setting-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.setting-item:last-child { border-bottom: none; }
.setting-left { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.setting-icon { font-size: 36rpx; }
.setting-info { display: flex; flex-direction: column; }
.setting-name { font-size: 28rpx; color: #333; font-weight: 500; }
.setting-desc { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.setting-arrow { font-size: 36rpx; color: #ccc; }
.setting-item.danger .setting-name { color: #ef4444; }
.footer { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 40rpx; gap: 8rpx; }
.footer-text { font-size: 22rpx; color: #ccc; }
.modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center; }
.modal.active { display: flex; }
.modal-content { background: #fff; width: 600rpx; border-radius: 24rpx; overflow: hidden; }
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 36rpx; border-bottom: 1rpx solid #f5f5f5; }
.modal-title { font-size: 32rpx; font-weight: bold; color: #333; }
.modal-close { font-size: 36rpx; color: #999; padding: 10rpx; }
.modal-body { padding: 36rpx; }
.modal-desc { font-size: 28rpx; color: #666; line-height: 1.6; }
.modal-footer { display: flex; border-top: 1rpx solid #f5f5f5; }
.modal-btn { flex: 1; padding: 28rpx 0; text-align: center; font-size: 30rpx; }
.modal-btn.cancel { color: #666; border-right: 1rpx solid #f5f5f5; }
.modal-btn.confirm { color: #667eea; font-weight: bold; }
.import-options { display: flex; flex-direction: column; gap: 20rpx; margin-top: 24rpx; }
.import-option { display: flex; align-items: center; gap: 20rpx; padding: 24rpx; border-radius: 16rpx; border: 2rpx solid #eee; }
.import-option.selected { border-color: #667eea; background: #f5f3ff; }
.option-icon { font-size: 36rpx; }
.option-info { display: flex; flex-direction: column; }
.option-title { font-size: 28rpx; color: #333; font-weight: 500; }
.option-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }