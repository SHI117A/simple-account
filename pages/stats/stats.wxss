.overview-card { background: #fff; border-radius: 24rpx; padding: 36rpx; margin-bottom: 24rpx; }
.overview-row { display: flex; justify-content: space-between; align-items: center; }
.overview-item { flex: 1; display: flex; flex-direction: column; align-items: center; }
.overview-label { font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.overview-value { font-size: 34rpx; font-weight: bold; }
.overview-value.income { color: #10b981; }
.overview-value.expense { color: #ef4444; }
.overview-divider { width: 1rpx; height: 60rpx; background: #eee; }
.overview-count { text-align: center; margin-top: 20rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }
.count-text { font-size: 24rpx; color: #bbb; }

.filter-bar { background: #fff; border-radius: 24rpx; padding: 20rpx 24rpx; margin-bottom: 24rpx; }
.filter-tabs { display: flex; gap: 16rpx; flex-wrap: wrap; }
.filter-tab {
  padding: 12rpx 28rpx; border-radius: 32rpx; font-size: 26rpx; color: #666;
  background: #f5f5f5; transition: all 0.2s ease;
}
.filter-tab.active { background: #667eea; color: #fff; }

.custom-date-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 200; display: flex; align-items: center; justify-content: center;
  background: rgba(0, 0, 0, 0); pointer-events: none;
  transition: background 0.2s ease;
}
.custom-date-overlay.show { background: rgba(0, 0, 0, 0.5); pointer-events: auto; }

.custom-date-panel {
  width: 85%; background: #fff; border-radius: 24rpx; overflow: hidden;
  transform: scale(0.85); opacity: 0;
  transition: transform 0.25s ease, opacity 0.25s ease;
}
.custom-date-panel.show { transform: scale(1); opacity: 1; }

.custom-date-header { padding: 30rpx 36rpx 20rpx; }
.custom-date-title { font-size: 32rpx; font-weight: bold; color: #333; }

.custom-date-body { padding: 0 36rpx 30rpx; }
.date-picker-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 0; border-bottom: 1rpx solid #f5f5f5;
}
.date-picker-row:last-child { border-bottom: none; }
.date-label { font-size: 28rpx; color: #666; }
.date-value {
  font-size: 28rpx; color: #667eea; padding: 12rpx 24rpx;
  background: #f5f7ff; border-radius: 16rpx;
}

.custom-date-footer { display: flex; border-top: 1rpx solid #f0f0f0; }
.date-btn {
  flex: 1; text-align: center; padding: 28rpx 0; font-size: 30rpx;
}
.date-btn.cancel { color: #999; border-right: 1rpx solid #f0f0f0; }
.date-btn.confirm { color: #667eea; font-weight: bold; }

.section { background: #fff; border-radius: 24rpx; padding: 36rpx; margin-bottom: 30rpx; }

.rank-tabs { display: flex; gap: 0; margin-bottom: 28rpx; border-bottom: 2rpx solid #f0f0f0; }
.rank-tab {
  flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; color: #999;
  position: relative; transition: color 0.2s ease;
}
.rank-tab.active { color: #333; font-weight: bold; }
.rank-tab.active::after {
  content: ''; position: absolute; bottom: -2rpx; left: 50%; transform: translateX(-50%);
  width: 60rpx; height: 4rpx; border-radius: 2rpx;
}
.rank-tab.expense-active::after { background: #ef4444; }
.rank-tab.income-active::after { background: #10b981; }

.empty-tip { text-align: center; color: #999; padding: 60rpx 0; font-size: 26rpx; }
.rank-list { display: flex; flex-direction: column; gap: 20rpx; }
.rank-item { display: flex; align-items: center; justify-content: space-between; }
.rank-left { display: flex; align-items: center; gap: 16rpx; flex-shrink: 0; }
.rank-index { width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center; }
.rank-badge { font-size: 22rpx; font-weight: bold; color: #fff; width: 40rpx; height: 40rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.rank-badge.gold { background: #f59e0b; }
.rank-badge.silver { background: #9ca3af; }
.rank-badge.bronze { background: #d97706; }
.rank-num { font-size: 26rpx; color: #999; }
.rank-emoji { font-size: 32rpx; }
.rank-name { font-size: 28rpx; color: #333; }
.rank-right { display: flex; align-items: center; gap: 16rpx; flex: 1; justify-content: flex-end; }
.rank-amount { font-size: 28rpx; font-weight: bold; min-width: 100rpx; text-align: right; }
.rank-amount.expense-text { color: #ef4444; }
.rank-amount.income-text { color: #10b981; }
.rank-bar-wrap { width: 120rpx; height: 12rpx; background: #f0f0f0; border-radius: 6rpx; overflow: hidden; }
.rank-bar { height: 100%; background: linear-gradient(90deg, #667eea, #764ba2); border-radius: 6rpx; }
.rank-bar.income-bar { background: linear-gradient(90deg, #10b981, #059669); }

.merchant-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100; display: flex; align-items: center; justify-content: center;
  background: rgba(0, 0, 0, 0); pointer-events: none;
  transition: background 0.2s ease;
}
.merchant-overlay.show { background: rgba(0, 0, 0, 0.5); pointer-events: auto; }

.merchant-panel {
  width: 80%; max-height: 70vh; background: #fff; border-radius: 24rpx;
  overflow: hidden; display: flex; flex-direction: column;
  transform: scale(0.8); opacity: 0;
  transition: transform 0.25s ease, opacity 0.25s ease;
}
.merchant-panel.show { transform: scale(1); opacity: 1; }

.merchant-header {
  padding: 30rpx 36rpx 20rpx; border-bottom: 1rpx solid #f0f0f0;
  display: flex; align-items: center; justify-content: space-between;
}
.merchant-title { font-size: 30rpx; font-weight: bold; color: #333; }
.merchant-total { font-size: 26rpx; font-weight: bold; }

.merchant-table-header {
  display: flex; align-items: center; padding: 16rpx 36rpx;
  background: #fafafa; border-bottom: 1rpx solid #f0f0f0;
}
.th-name { flex: 1; font-size: 22rpx; color: #999; }
.th-count { width: 70rpx; text-align: center; font-size: 22rpx; color: #999; }
.th-amount { width: 110rpx; text-align: right; font-size: 22rpx; color: #999; }
.th-percent { width: 80rpx; text-align: right; font-size: 22rpx; color: #999; }

.merchant-scroll { flex: 1; max-height: 50vh; padding: 8rpx 0; }

.merchant-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 36rpx; }
.merchant-item-left { flex: 1; overflow: hidden; }
.merchant-item-name { font-size: 28rpx; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }
.merchant-item-right { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; margin-left: 20rpx; }
.merchant-item-count { font-size: 24rpx; color: #999; width: 70rpx; text-align: center; }
.merchant-item-amount { font-size: 28rpx; font-weight: bold; width: 110rpx; text-align: right; }
.merchant-item-percent { font-size: 24rpx; color: #999; width: 80rpx; text-align: right; }

.merchant-footer { padding: 20rpx; text-align: center; border-top: 1rpx solid #f0f0f0; }
.merchant-footer-text { font-size: 24rpx; color: #bbb; }
